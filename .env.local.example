# Copy this file to .env.local and fill in your values
# Get this from: Vercel Dashboard → Storage/Marketplace → Postgres/Neon integration → .env.local
POSTGRES_URL=postgres://user:password@host/database?sslmode=require

# Temporary: only needed for one-time KV -> Postgres migration endpoint
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MIGRATION_TOKEN=set-a-random-secret-token
